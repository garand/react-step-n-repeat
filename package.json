{
  "name": "react-step-n-repeat",
  "version": "0.1.2",
  "packageManager": "pnpm@11.1.2",
  "type": "module",
  "description": "A React component for tiled step-and-repeat layouts with staggered rows and optional row animation.",
  "author": "garand",
  "license": "MIT",
  "keywords": [
    "react",
    "component",
    "pattern",
    "layout",
    "animation"
  ],
  "homepage": "https://github.com/garand/react-step-n-repeat#readme",
  "bugs": {
    "url": "https://github.com/garand/react-step-n-repeat/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/garand/react-step-n-repeat.git"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "./dist/styles.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && cp src/components/StepAndRepeat.css dist/styles.css",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "pnpm lint && pnpm build && pnpm build-storybook"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/react-vite": "^10.4.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vite-plugin-dts": "^4.5.4"
  }
}
